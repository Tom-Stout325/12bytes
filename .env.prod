ENV_NAME=prod
DEBUG=False
ALLOWED_HOSTS=your-app.herokuapp.com
CSRF_TRUSTED_ORIGINS=https://your-app.herokuapp.com
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/12bytes_prod
DB_SSLMODE=require
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@12bytes.app
USE_S3=False
